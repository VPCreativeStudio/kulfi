---
interface Props {
  image: string;
  menu: string;
  category: string;
}

const { image, menu, category } = Astro.props;
---

<div class="menu-card" data-category={category}>
  <div class="image">
    <img src={`../../src/assets/images/${image}`} alt={menu} />
  </div>
  <h3 class="menu-name">{menu}</h3>
</div>

<style lang="scss" is:global>
  @use "../assets/scss/mixin" as *;
  @use "../assets/scss/root" as *;

  .menu-card {
    background: var(--whiteClr);
    border-radius: var(--rd-16);
    @include flex-element;
    flex-direction: column;
    width: 18rem;
    overflow: hidden;
    border-radius: var(--rd-16);
    box-shadow: var(--menuBoxShadow);

    .image {
      width: 100%;
      height: 18rem;
      overflow: hidden;

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;

        &:hover {
          transform: scale(1.05);
        }
      }
    }

    .menu-name {
      font-family: var(--fontHdBold);
      font-size: 1rem;
      line-height: 1.5rem;
      text-align: center;
      padding: 1rem;
    }
  }
</style>

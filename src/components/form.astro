---
import FormInput from "./form-input.astro";
import Button from "./button.astro";
---

<div class="form-wrapper">
  <div class="form-heading">
    <h4>Franchise Enquiry Form</h4>
    <span>Get started with Bezt Kulfis today</span>
  </div>
  <form>
    <FormInput label="Your Name" inputType="text" name="name" />
    <FormInput label="Phone Number" inputType="number" name="phone" />
    <FormInput label="City / Location" inputType="text" name="location" />
    <div class="input-form">
      <label for="message">Message (Optional)</label>
      <textarea id="message" name="message" rows="2"></textarea>
    </div>
    <Button label="Send Enquiry via WhatsApp" btnClasses="btn-primary" />
  </form>
</div>

<style lang="scss" is:global>
  @use "../assets/scss/mixin" as *;
  @use "../assets/scss/root" as *;

  .form-wrapper {
    background: var(--whiteClr-80);
    border-radius: var(--rd-24);
    padding: 1.5rem;
    width: 22rem;
    height: max-content;
    margin: auto;

    .form-heading {
      text-align: center;
      margin-bottom: 1.5rem;

      h4 {
        font-family: var(--fontHdBold);
        font-size: var(--ft-20);
        line-height: var(--ft-24);
        color: var(--textClr);
      }

      span {
        font-family: var(--fontRegular);
        font-size: var(--ft-12);
        line-height: var(--ft-16);
        color: var(--secondaryTextClr);
      }
    }

    form {
      @include flex-element;
      flex-direction: column;
      gap: 0.75rem;
      align-items: center;

      button {
        width: 100%;
      }
    }
  }
</style>
